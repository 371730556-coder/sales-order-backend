# 数据库连接
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sales_orders

# JWT 密钥（生产环境请使用随机生成的强密钥）
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# 服务端口
PORT=3000

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5500
