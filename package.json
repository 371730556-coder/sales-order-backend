{
  "name": "sales-order-backend",
  "version": "1.0.0",
  "description": "销售工单管理系统后端 API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:init": "psql $DATABASE_URL -f schema.sql",
    "db:seed": "node seed-passwords.js && psql $DATABASE_URL -f seed.sql",
    "db:setup": "npm run db:init && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
